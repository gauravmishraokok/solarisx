# LLM
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...          # optional fallback

# Databases
DATABASE_URL=postgresql+asyncpg://memora:memora@localhost:5432/memora
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=memorapass
REDIS_URL=redis://localhost:6379

# Memory Court
CONTRADICTION_THRESHOLD=0.75   # 0.0–1.0; above this = quarantine

# Retrieval
TOP_K_RETRIEVAL=5
CONTEXT_WINDOW_BUDGET=8000     # tokens before MemGPT pager kicks in

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
